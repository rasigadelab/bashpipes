Bootstrap: docker
From: staphb/bowtie2:2.5.4

%post
  # Install updates and dependencies
  apt-get update && apt-get install -y wget unzip make gcc zlib1g-dev libncurses5-dev libncursesw5-dev \
  libbz2-dev liblzma-dev curl build-essential python3 git autoconf
  # Install HTSlib
  cd /opt
  wget https://github.com/samtools/htslib/releases/download/1.22.1/htslib-1.22.1.tar.bz2
  tar -vxjf htslib-1.22.1.tar.bz2
  cd htslib-1.22.1
  autoreconf -i
  ./configure
  make
  make install
  # Install Samtools
  cd /opt
  wget https://github.com/samtools/samtools/releases/download/1.22.1/samtools-1.22.1.tar.bz2
  tar -vxjf samtools-1.22.1.tar.bz2  
  cd samtools-1.22.1
  autoheader
  autoconf -Wno-syntax
  ./configure --prefix=/usr/local
  make
  make install
  # Clean up
  cd /
  rm -rf /opt/htslib-1.21 /opt/samtools-1.21
  apt-get clean
  rm -rf /var/lib/apt/lists/*

%labels
    org.opencontainers.image.title "bowtie2 + samtools container"
    org.opencontainers.image.description "Container for genome assembly (bowtie2, samtools)"
    org.opencontainers.image.authors "Aurélie Fischer (PHE3ID, CIRI, Hospices Civils de Lyon)"
    org.opencontainers.image.version "1.0.0"
    org.opencontainers.image.licenses "AGPL-3.0-only + bundled tool licenses"
    org.opencontainers.image.source "https://github.com/rasigadelab/bashpipes"
